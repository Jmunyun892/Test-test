# Copy to .env.local for local dev, or set in Vercel / your host dashboard.
# Never commit real secrets.

# --- Zoom OAuth (Marketplace OAuth app) ---
NEXT_PUBLIC_ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
NEXT_PUBLIC_ZOOM_REDIRECT_URI=http://localhost:3000/api/zoom/callback
# Optional: space-separated granular scopes (must match your Zoom app)
# ZOOM_OAUTH_SCOPES=user:read:user cloud_recording:read:list_user_recordings

# --- Microsoft / Outlook (Entra app registration) ---
NEXT_PUBLIC_MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
NEXT_PUBLIC_MICROSOFT_REDIRECT_URI=http://localhost:3000/api/outlook/callback
# Optional: defaults to "common"
# MICROSOFT_TENANT_ID=common

# --- In-app Zoom recording proxy (recommended in production) ---
ZOOM_STREAM_SECRET=
